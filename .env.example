# ============================================================
#  Plataforma de Análisis Estadístico Académico - Variables
# ============================================================
# Copia este archivo a .env y completa los valores faltantes.
# El script start.sh genera automáticamente .env la primera vez.

# ---------- Postgres ----------
POSTGRES_DB=academia
POSTGRES_USER=academia
POSTGRES_PASSWORD=cambiar_password_seguro

# ---------- Redis ----------
# (sin contraseña en red interna)

# ---------- Seguridad / JWT ----------
# Mínimo 32 caracteres. Genera con: openssl rand -hex 32
JWT_SECRET=cambiar_con_openssl_rand_hex_32_xxxxxxxxxxxxxxxxx

# ---------- CORS ----------
# Lista separada por comas de orígenes permitidos
ALLOWED_ORIGINS=http://localhost,http://192.168.0.10

# ---------- Admin inicial ----------
INITIAL_ADMIN_EMAIL=admin@universidad.edu
INITIAL_ADMIN_PASSWORD=cambiar_password_admin_seguro

# ---------- Subidas ----------
UPLOAD_MAX_SIZE_MB=200

# ---------- Puerto público ----------
HTTP_PORT=80
